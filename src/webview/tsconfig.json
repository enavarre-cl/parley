{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "checkJs": true,
    "noEmit": true,
    "allowJs": true,
    "strict": false,
    "skipLibCheck": true,
    "types": []
  },
  "include": ["globals.d.ts", "core/**/*", "render/**/*", "ui/**/*", "features/**/*", "chat/**/*", "panels/**/*", "app/**/*"],
  "exclude": ["node_modules", "dist"]
}
