{
  "name": "parley-io",
  "displayName": "Parley.IO",
  "description": "%ext.description%",
  "version": "1.2.3",
  "publisher": "enavarre",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Chat",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "%capabilities.untrustedWorkspaces.desc%"
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "parley.new",
        "title": "%cmd.new.title%",
        "icon": "$(add)"
      },
      {
        "command": "parley.setApiKey",
        "title": "%cmd.setApiKey.title%"
      },
      {
        "command": "parley.models.add",
        "title": "%cmd.models.add.title%",
        "category": "Parley",
        "icon": "$(add)"
      },
      {
        "command": "parley.models.refresh",
        "title": "%cmd.models.refresh.title%",
        "category": "Parley",
        "icon": "$(refresh)"
      },
      {
        "command": "parley.models.startServer",
        "title": "%cmd.models.startServer.title%",
        "category": "Parley",
        "icon": "$(play)"
      },
      {
        "command": "parley.models.stopServer",
        "title": "%cmd.models.stopServer.title%",
        "category": "Parley",
        "icon": "$(debug-stop)"
      },
      {
        "command": "parley.models.deleteModel",
        "title": "%cmd.models.deleteModel.title%",
        "category": "Parley",
        "icon": "$(close)"
      },
      {
        "command": "parley.models.cancelDownload",
        "title": "%cmd.models.cancelDownload.title%",
        "category": "Parley",
        "icon": "$(stop-circle)"
      },
      {
        "command": "parley.models.retryDownload",
        "title": "%cmd.models.retryDownload.title%",
        "category": "Parley",
        "icon": "$(refresh)"
      },
      {
        "command": "parley.models.removeDownload",
        "title": "%cmd.models.removeDownload.title%",
        "category": "Parley",
        "icon": "$(close)"
      },
      {
        "command": "parley.models.clearDownloads",
        "title": "%cmd.models.clearDownloads.title%",
        "category": "Parley",
        "icon": "$(clear-all)"
      },
      {
        "command": "parley.models.openModelFromDownload",
        "title": "%cmd.models.openModelFromDownload.title%",
        "category": "Parley",
        "icon": "$(go-to-file)"
      },
      {
        "command": "parley.models.openLocalModel",
        "title": "%cmd.models.openLocalModel.title%",
        "category": "Parley"
      },
      {
        "command": "parley.compareVersion",
        "title": "%cmd.compareVersion.title%",
        "category": "Parley",
        "icon": "$(git-compare)"
      },
      {
        "command": "parley.spell.openDictionary",
        "title": "%cmd.spell.openDictionary.title%",
        "category": "Parley"
      },
      {
        "command": "parley.tts.openVoices",
        "title": "%cmd.tts.openVoices.title%",
        "category": "Parley",
        "icon": "$(add)"
      },
      {
        "command": "parley.tts.startServer",
        "title": "%cmd.tts.startServer.title%",
        "category": "Parley",
        "icon": "$(play)"
      },
      {
        "command": "parley.tts.stopServer",
        "title": "%cmd.tts.stopServer.title%",
        "category": "Parley",
        "icon": "$(debug-stop)"
      },
      {
        "command": "parley.tts.removeVoice",
        "title": "%cmd.tts.removeVoice.title%",
        "category": "Parley",
        "icon": "$(trash)"
      },
      {
        "command": "parley.engine.install",
        "title": "%cmd.engine.install.title%",
        "category": "Parley",
        "icon": "$(cloud-download)"
      },
      {
        "command": "parley.engine.delete",
        "title": "%cmd.engine.delete.title%",
        "category": "Parley",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "parley",
          "title": "Parley",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "parley": [
        {
          "id": "parley.engines",
          "name": "%view.engines.name%",
          "icon": "media/icon.svg"
        },
        {
          "id": "parley.models",
          "name": "%view.models.name%",
          "icon": "media/icon.svg"
        },
        {
          "id": "parley.voices",
          "name": "%view.voices.name%",
          "icon": "media/icon.svg"
        },
        {
          "id": "parley.dictionary",
          "name": "%view.dictionary.name%",
          "icon": "media/icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "parley.models.add",
          "when": "view == parley.models",
          "group": "navigation@1"
        },
        {
          "command": "parley.models.refresh",
          "when": "view == parley.models",
          "group": "navigation@2"
        },
        {
          "command": "parley.tts.openVoices",
          "when": "view == parley.voices",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "parley.models.startServer",
          "when": "view == parley.engines && viewItem == engine.ollama.stopped",
          "group": "inline@1"
        },
        {
          "command": "parley.models.stopServer",
          "when": "view == parley.engines && viewItem == engine.ollama.running",
          "group": "inline@1"
        },
        {
          "command": "parley.engine.install",
          "when": "view == parley.engines && viewItem =~ /engine\\.(ollama|piper)\\.notinstalled/",
          "group": "inline@1"
        },
        {
          "command": "parley.tts.startServer",
          "when": "view == parley.engines && viewItem == engine.piper.stopped",
          "group": "inline@1"
        },
        {
          "command": "parley.tts.stopServer",
          "when": "view == parley.engines && viewItem == engine.piper.running",
          "group": "inline@1"
        },
        {
          "command": "parley.engine.delete",
          "when": "view == parley.engines && viewItem =~ /engine\\.(ollama|piper)\\.(stopped|running)/",
          "group": "inline@3"
        },
        {
          "command": "parley.models.deleteModel",
          "when": "view == parley.models && viewItem == ollamaModel",
          "group": "inline"
        },
        {
          "command": "parley.models.clearDownloads",
          "when": "view == parley.models && viewItem == ollamaDownloads",
          "group": "inline"
        },
        {
          "command": "parley.models.cancelDownload",
          "when": "view == parley.models && viewItem =~ /ollamaDownload\\.(downloading|queued)/",
          "group": "inline"
        },
        {
          "command": "parley.models.retryDownload",
          "when": "view == parley.models && viewItem == ollamaDownload.failed",
          "group": "inline@1"
        },
        {
          "command": "parley.models.removeDownload",
          "when": "view == parley.models && viewItem == ollamaDownload.failed",
          "group": "inline@2"
        },
        {
          "command": "parley.models.openModelFromDownload",
          "when": "view == parley.models && viewItem =~ /ollamaDownload\\./",
          "group": "navigation"
        },
        {
          "command": "parley.spell.openDictionary",
          "when": "view == parley.dictionary && viewItem == spellDictLang",
          "group": "inline"
        },
        {
          "command": "parley.tts.removeVoice",
          "when": "view == parley.voices && viewItem == piperVoice",
          "group": "inline"
        }
      ],
      "timeline/item/context": [
        {
          "command": "parley.compareVersion",
          "when": "timelineItem =~ /localHistory/ && resourceExtname == .chat",
          "group": "1_actions"
        }
      ],
      "editor/title": [
        {
          "command": "parley.compareVersion",
          "when": "activeCustomEditorId == parley.editor",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "parley.compareVersion",
          "when": "resourceExtname == .chat"
        },
        {
          "command": "parley.spell.openDictionary",
          "when": "false"
        },
        {
          "command": "parley.tts.openVoices",
          "when": "false"
        },
        {
          "command": "parley.tts.startServer",
          "when": "false"
        },
        {
          "command": "parley.tts.stopServer",
          "when": "false"
        },
        {
          "command": "parley.tts.removeVoice",
          "when": "false"
        },
        {
          "command": "parley.engine.install",
          "when": "false"
        },
        {
          "command": "parley.engine.delete",
          "when": "false"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "parley.editor",
        "displayName": "Parley",
        "selector": [
          {
            "filenamePattern": "*.chat"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": [
      {
        "title": "%config.title.general%",
        "order": 1,
        "properties": {
          "parley.language": {
            "type": "string",
            "enum": [
              "auto",
              "en",
              "es",
              "pt",
              "fr",
              "de",
              "it"
            ],
            "enumDescriptions": [
              "%config.language.enum.auto%",
              "English",
              "Español",
              "Português",
              "Français",
              "Deutsch",
              "Italiano"
            ],
            "default": "auto",
            "description": "%config.language.desc%"
          },
          "parley.provider": {
            "type": "string",
            "enum": [
              "openai",
              "ollama",
              "gemini",
              "anthropic",
              "openrouter"
            ],
            "enumDescriptions": [
              "%config.provider.enum.openai%",
              "%config.provider.enum.ollama%",
              "%config.provider.enum.gemini%",
              "%config.provider.enum.anthropic%",
              "%config.provider.enum.openrouter%"
            ],
            "default": "openai",
            "description": "%config.provider.desc%"
          },
          "parley.temperature": {
            "type": "number",
            "default": 0.7,
            "minimum": 0,
            "maximum": 2,
            "description": "%config.temperature.desc%"
          },
          "parley.maxTokens": {
            "type": "number",
            "default": 2048,
            "description": "%config.maxTokens.desc%"
          }
        }
      },
      {
        "title": "LM Studio / OpenAI",
        "order": 2,
        "properties": {
          "parley.openai.baseUrl": {
            "type": "string",
            "default": "http://localhost:1234/v1",
            "description": "%config.openai.baseUrl.desc%"
          },
          "parley.openai.apiKey": {
            "type": "string",
            "default": "",
            "description": "%config.openai.apiKey.desc%"
          }
        }
      },
      {
        "title": "Ollama",
        "order": 3,
        "properties": {
          "parley.ollama.managed": {
            "type": "boolean",
            "default": true,
            "description": "%config.ollama.managed.desc%"
          },
          "parley.ollama.port": {
            "type": "number",
            "default": 0,
            "markdownDescription": "%config.ollama.port.desc%"
          },
          "parley.ollama.modelsPath": {
            "type": "string",
            "default": "",
            "markdownDescription": "%config.ollama.modelsPath.desc%"
          },
          "parley.ollama.maxConcurrentDownloads": {
            "type": "number",
            "default": 2,
            "minimum": 1,
            "maximum": 6,
            "markdownDescription": "%config.ollama.maxConcurrentDownloads.desc%"
          },
          "parley.ollama.baseUrl": {
            "type": "string",
            "default": "http://localhost:11434",
            "markdownDescription": "%config.ollama.baseUrl.desc%"
          }
        }
      },
      {
        "title": "Google Gemini",
        "order": 4,
        "properties": {
          "parley.gemini.apiKey": {
            "type": "string",
            "default": "",
            "description": "%config.gemini.apiKey.desc%"
          },
          "parley.gemini.baseUrl": {
            "type": "string",
            "default": "https://generativelanguage.googleapis.com/v1beta",
            "description": "%config.gemini.baseUrl.desc%"
          }
        }
      },
      {
        "title": "Anthropic",
        "order": 5,
        "properties": {
          "parley.anthropic.apiKey": {
            "type": "string",
            "default": "",
            "description": "%config.anthropic.apiKey.desc%"
          },
          "parley.anthropic.baseUrl": {
            "type": "string",
            "default": "https://api.anthropic.com/v1",
            "description": "%config.anthropic.baseUrl.desc%"
          }
        }
      },
      {
        "title": "OpenRouter",
        "order": 6,
        "properties": {
          "parley.openrouter.apiKey": {
            "type": "string",
            "default": "",
            "description": "%config.openrouter.apiKey.desc%"
          },
          "parley.openrouter.baseUrl": {
            "type": "string",
            "default": "https://openrouter.ai/api/v1",
            "description": "%config.openrouter.baseUrl.desc%"
          },
          "parley.openrouter.vendors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "markdownDescription": "%config.openrouter.vendors.desc%"
          },
          "parley.openrouter.customModels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "markdownDescription": "%config.openrouter.customModels.desc%"
          },
          "parley.openrouter.sort": {
            "type": "string",
            "enum": [
              "",
              "throughput",
              "latency",
              "price"
            ],
            "enumDescriptions": [
              "%config.openrouter.sort.enum.default%",
              "%config.openrouter.sort.enum.throughput%",
              "%config.openrouter.sort.enum.latency%",
              "%config.openrouter.sort.enum.price%"
            ],
            "default": "",
            "markdownDescription": "%config.openrouter.sort.desc%"
          }
        }
      },
      {
        "title": "%config.title.tools%",
        "order": 7,
        "properties": {
          "parley.tools.maxReadBytes": {
            "type": "number",
            "default": 100000,
            "minimum": 0,
            "markdownDescription": "%config.tools.maxReadBytes.desc%"
          },
          "parley.tools.maxIterations": {
            "type": "number",
            "default": 8,
            "minimum": 0,
            "markdownDescription": "%config.tools.maxIterations.desc%"
          }
        }
      },
      {
        "title": "%config.title.tts%",
        "order": 8,
        "properties": {
          "parley.tts.piperPath": {
            "type": "string",
            "default": "piper",
            "markdownDescription": "%config.tts.piperPath.desc%"
          },
          "parley.tts.piperModel": {
            "type": "string",
            "default": "",
            "markdownDescription": "%config.tts.piperModel.desc%"
          },
          "parley.tts.piperSpeaker": {
            "type": "number",
            "default": -1,
            "markdownDescription": "%config.tts.piperSpeaker.desc%"
          },
          "parley.tts.debug": {
            "type": "boolean",
            "default": false,
            "description": "%config.tts.debug.desc%"
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test out/test/*.test.js",
    "lint": "eslint src",
    "package": "vsce package",
    "build:spell": "node scripts/build-spell.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "dictionary-de": "^3.0.0",
    "dictionary-en": "^4.0.0",
    "dictionary-es": "^4.0.0",
    "dictionary-fr": "^3.0.0",
    "dictionary-it": "^2.0.0",
    "dictionary-pt": "^4.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "nspell": "^2.1.5",
    "typescript": "^5.4.0"
  },
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "keywords": [
    "chat",
    "llm",
    "ai",
    "openai",
    "anthropic",
    "gemini",
    "ollama",
    "openrouter",
    "lm studio",
    "mcp",
    "tools",
    "copilot",
    "assistant"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/enavarre-cl/parley"
  },
  "bugs": {
    "url": "https://github.com/enavarre-cl/parley/issues"
  },
  "homepage": "https://github.com/enavarre-cl/parley#readme",
  "dependencies": {
    "undici": "^6.26.0"
  }
}
